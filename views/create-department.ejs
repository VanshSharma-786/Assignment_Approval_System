<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Create Department | University Assignment Approval</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="admin-layout">
    <header class="admin-header-bar">
      <a href="/admin/dashboard" class="admin-logo-title" style="color: inherit;">Admin Dashboard</a>
      <div class="navbar-menu" style="margin: 0;">
        <div class="user-profile">
          <div class="user-avatar" id="avatar-display">
            <%= user.email.charAt(0).toUpperCase() %>
          </div>
          <span><%= user.email %></span>
        </div>
        <form action="/auth/logout" method="GET" style="margin: 0;">
          <button type="submit" class="btn-logout" id="logout-btn">Sign Out</button>
        </form>
      </div>
    </header>

    <div class="admin-container">
      <aside class="admin-sidebar">
        <h2 class="sidebar-title">Navigation</h2>
        <nav class="sidebar-menu">
          <a href="/admin/departments" class="sidebar-link">Departments</a>
          <a href="/admin/users" class="sidebar-link">Users</a>
          <a href="/admin/users/add" class="sidebar-link">Add User</a>
        </nav>
      </aside>

      <main class="admin-content">
        <header class="dashboard-header" style="margin-bottom: 24px;">
          <h2 class="dashboard-title" style="font-size: 22px;">Create Department</h2>
        </header>

        <% if (error) { %>
          <div class="alert alert-danger" role="alert" style="max-width: 600px;">
            <span class="alert-icon">!</span>
            <span><%= error %></span>
          </div>
        <% } %>

        <div class="card-form">
          <form action="/admin/departments/create" method="POST">
            <div class="form-group">
              <label for="name" class="form-label">Department Name</label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                class="form-input" 
                placeholder="e.g. Computer Science" 
                required
              >
            </div>

            <div class="form-group">
              <label for="type" class="form-label">Program Type</label>
              <div class="input-wrapper">
                <select id="type" name="type" class="form-input form-select" required>
                  <option value="" disabled selected>Select Program Type</option>
                  <option value="UG">Undergraduate (UG)</option>
                  <option value="PG">Postgraduate (PG)</option>
                  <option value="Research">Research</option>
                </select>
              </div>
            </div>

            <div class="form-group">
              <label for="address" class="form-label">Address / Location</label>
              <textarea 
                id="address" 
                name="address" 
                class="form-input" 
                placeholder="e.g. Block A, Room 302" 
                required
              ></textarea>
            </div>

            <div style="display: flex; gap: 16px; margin-top: 32px;">
              <button type="submit" class="btn btn-primary" style="flex: 1;">Create Department</button>
              <a href="/admin/departments" class="btn btn-secondary" style="flex: 1; border: 1px solid var(--border-color); color: var(--text-main); text-align: center;">Cancel</a>
            </div>
          </form>
        </div>
      </main>
    </div>

    <footer class="admin-footer">
      <p>&copy; 2025 Admin Dashboard. All rights reserved.</p>
    </footer>
  </div>
</body>
</html>
