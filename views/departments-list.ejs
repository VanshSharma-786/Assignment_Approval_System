<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>All Departments | University Assignment Approval</title>
  <link rel="stylesheet" href="/css/style.css">
</head>

<body>
  <div class="admin-layout">
    <header class="admin-header-bar">
      <a href="/admin/dashboard" class="admin-logo-title" style="color: inherit;">Admin Dashboard</a>
      <div class="navbar-menu" style="margin: 0;">
        <div class="user-profile">
          <div class="user-avatar" id="avatar-display">
            <%= user.email.charAt(0).toUpperCase() %>
          </div>
          <span>
            <%= user.email %>
          </span>
        </div>
        <form action="/auth/logout" method="GET" style="margin: 0;">
          <button type="submit" class="btn-logout" id="logout-btn">Sign Out</button>
        </form>
      </div>
    </header>

    <div class="admin-container">
      <aside class="admin-sidebar">
        <h2 class="sidebar-title">Navigation</h2>
        <nav class="sidebar-menu">
          <a href="/admin/departments" class="sidebar-link"
            style="background-color: var(--primary); color: var(--text-inverse);">Departments</a>
          <a href="/admin/users" class="sidebar-link">Users</a>
          <a href="/admin/users/add" class="sidebar-link">Add User</a>
        </nav>
      </aside>

      <main class="admin-content">
        <header class="dashboard-header"
          style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
          <div>
            <h2 class="dashboard-title" style="font-size: 22px; margin-bottom: 4px;">All Departments</h2>
          </div>
          <a href="/admin/departments/create" class="btn-header-action">
            Add Department
          </a>
        </header>

        <% if (success) { %>
          <div class="alert alert-success" role="alert" id="success-banner">
            <span class="alert-icon" style="background: currentColor;">✓</span>
            <span>
              <%= success %>
            </span>
          </div>
        <% } %>

        <% if (error) { %>
          <div class="alert alert-danger" role="alert" id="error-banner">
            <span class="alert-icon">!</span>
            <span>
              <%= error %>
            </span>
          </div>
        <% } %>

            <div class="filter-bar">
              <div class="filter-group">
                <label for="search-input" class="form-label">Search</label>
                <input type="text" id="search-input" class="form-input" placeholder="Search by department name">
              </div>
              <div class="filter-group">
                <label for="type-filter" class="form-label">Filter by Type</label>
                <div class="input-wrapper">
                  <select id="type-filter" class="form-input form-select">
                    <option value="All">All</option>
                    <option value="UG">UG</option>
                    <option value="PG">PG</option>
                    <option value="Research">Research</option>
                  </select>
                </div>
              </div>
            </div>

            <div class="table-container">
              <table class="admin-table">
                <thead>
                  <tr>
                    <th>Department Name</th>
                    <th>Type</th>
                    <th>Number of Users</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody id="table-body">
                  <% if (departments.length===0) { %>
                    <tr id="empty-row">
                      <td colspan="4" style="text-align: center; color: var(--text-muted); padding: 32px;">
                        No departments created yet.
                      </td>
                    </tr>
                    <% } else { %>
                      <% departments.forEach(dept=> { %>
                        <tr class="dept-row" data-name="<%= dept.name %>" data-type="<%= dept.type %>">
                          <td style="font-weight: 600;">
                            <%= dept.name %>
                          </td>
                          <td>
                            <% if (dept.type==='UG' ) { %>
                              <span class="badge badge-info">UG</span>
                              <% } else if (dept.type==='PG' ) { %>
                                <span class="badge badge-warning">PG</span>
                                <% } else { %>
                                  <span class="badge badge-success">Research</span>
                                  <% } %>
                          </td>
                          <td>
                            <%= dept.dataValues.userCount || 0 %>
                          </td>
                          <td>
                            <div style="display: flex; gap: 8px; align-items: center;">
                              <a href="/admin/departments/edit/<%= dept.id %>" class="btn-table-edit">Edit</a>
                              <form action="/admin/departments/delete/<%= dept.id %>" method="POST" style="margin: 0;"
                                onsubmit="return confirm('Are you sure you want to delete this department?');">
                                <button type="submit" class="btn-table-delete">Delete</button>
                              </form>
                            </div>
                          </td>
                        </tr>
                        <% }); %>
                          <% } %>
                            <tr id="no-results-row" style="display: none;">
                              <td colspan="4" style="text-align: center; color: var(--text-muted); padding: 32px;">
                                No departments match your filters.
                              </td>
                            </tr>
                </tbody>
              </table>

              <div class="pagination-container">
                <span class="pagination-info" id="page-info">Page 1 of 1</span>
                <div class="pagination-buttons">
                  <button class="btn-pagination" id="prev-btn" disabled>Previous</button>
                  <button class="btn-pagination" id="next-btn" disabled>Next</button>
                </div>
              </div>
            </div>
      </main>
    </div>

    <footer class="admin-footer">
      <p>&copy; 2025 Admin Dashboard. All rights reserved.</p>
    </footer>
  </div>

  <script src="/scripts/departments-list.js"></script>
</body>

</html>