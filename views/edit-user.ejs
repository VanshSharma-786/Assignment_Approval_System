<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit User | University Assignment Approval</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="admin-layout">
    <header class="admin-header-bar">
      <a href="/admin/dashboard" class="admin-logo-title" style="color: inherit;">Admin Dashboard</a>
      <div class="navbar-menu" style="margin: 0;">
        <div class="user-profile">
          <div class="user-avatar" id="avatar-display">
            <%= user.email.charAt(0).toUpperCase() %>
          </div>
          <span><%= user.email %></span>
        </div>
        <form action="/auth/logout" method="GET" style="margin: 0;">
          <button type="submit" class="btn-logout" id="logout-btn">Sign Out</button>
        </form>
      </div>
    </header>

    <div class="admin-container">
      <aside class="admin-sidebar">
        <h2 class="sidebar-title">Navigation</h2>
        <nav class="sidebar-menu">
          <a href="/admin/departments" class="sidebar-link">Departments</a>
          <a href="/admin/users" class="sidebar-link">Users</a>
          <a href="/admin/users/add" class="sidebar-link">Add User</a>
        </nav>
      </aside>

      <main class="admin-content">
        <header class="dashboard-header" style="margin-bottom: 24px;">
          <h2 class="dashboard-title" style="font-size: 22px;">Edit User Account</h2>
        </header>

        <% if (error) { %>
          <div class="alert alert-danger" role="alert" style="max-width: 600px;">
            <span class="alert-icon">!</span>
            <span><%= error %></span>
          </div>
        <% } %>

        <div class="card-form">
          <form action="/admin/users/<%= targetUser.id %>/update" method="POST">
            <div class="form-group">
              <label for="name" class="form-label">Full Name</label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                class="form-input" 
                value="<%= targetUser.name || '' %>" 
                placeholder="e.g. John Doe" 
                required
              >
            </div>

            <div class="form-group">
              <label for="email" class="form-label">Email Address</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                class="form-input" 
                value="<%= targetUser.email %>" 
                placeholder="e.g. john.doe@university.edu" 
                required
              >
            </div>

            <div class="form-group">
              <label for="password" class="form-label">Password (leave blank to keep current password)</label>
              <input 
                type="password" 
                id="password" 
                name="password" 
                class="form-input" 
                placeholder="Enter new password" 
              >
            </div>

            <div class="form-group">
              <label for="phone" class="form-label">Phone Number</label>
              <input 
                type="tel" 
                id="phone" 
                name="phone" 
                class="form-input" 
                value="<%= targetUser.phone || '' %>" 
                placeholder="e.g. +1 (555) 019-2041"
              >
            </div>

            <div class="form-group">
              <label for="departmentId" class="form-label">Department</label>
              <div class="input-wrapper">
                <select id="departmentId" name="departmentId" class="form-input form-select" required>
                  <option value="">Select Department</option>
                  <% departments.forEach(dept => { %>
                    <option value="<%= dept.id %>" <%= targetUser.departmentId === dept.id ? 'selected' : '' %>><%= dept.name %></option>
                  <% }); %>
                </select>
              </div>
            </div>

            <div class="form-group">
              <label for="role" class="form-label">Role (disabled)</label>
              <div class="input-wrapper">
                <select id="role" class="form-input form-select" disabled style="opacity: 0.7; cursor: not-allowed;">
                  <option value="student" <%= targetUser.role === 'student' ? 'selected' : '' %>>Student</option>
                  <option value="professor" <%= targetUser.role === 'professor' ? 'selected' : '' %>>Professor</option>
                  <option value="hod" <%= targetUser.role === 'hod' ? 'selected' : '' %>>HOD</option>
                </select>
              </div>
            </div>

            <div style="display: flex; gap: 16px; margin-top: 32px;">
              <button type="submit" class="btn btn-primary" style="flex: 1;">Save Changes</button>
              <a href="/admin/users" class="btn btn-secondary" style="flex: 1; border: 1px solid var(--border-color); color: var(--text-main); text-align: center;">Cancel</a>
            </div>
          </form>
        </div>
      </main>
    </div>

    <footer class="admin-footer">
      <p>&copy; 2025 Admin Dashboard. All rights reserved.</p>
    </footer>
  </div>
</body>
</html>
