<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Assignments | Student Portal</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="admin-layout">
    <header class="admin-header-bar">
      <a href="/student/dashboard" class="admin-logo-title" style="color: inherit;">Student Portal</a>
      <div class="navbar-menu" style="margin: 0;">
        <div class="user-profile">
          <div class="user-avatar" id="avatar-display">
            <%= user.name.charAt(0).toUpperCase() %>
          </div>
          <span><%= user.email %></span>
        </div>
        <form action="/auth/logout" method="GET" style="margin: 0;">
          <button type="submit" class="btn-logout" id="logout-btn">Sign Out</button>
        </form>
      </div>
    </header>

    <div class="admin-container">
      <aside class="admin-sidebar">
        <h2 class="sidebar-title">Navigation</h2>
        <nav class="sidebar-menu">
          <a href="/student/dashboard" class="sidebar-link">Dashboard</a>
          <a href="/student/assignments" class="sidebar-link" style="background-color: var(--primary); color: var(--text-inverse);">All Assignments</a>
          <a href="/student/profile" class="sidebar-link">Profile</a>
        </nav>
      </aside>

      <main class="admin-content">
        <header class="dashboard-header" style="margin-bottom: 24px; display: flex; justify-content: space-between; align-items: center;">
          <h2 class="dashboard-title" style="font-size: 22px; margin: 0;">My Assignments</h2>
          <div style="display: flex; gap: 12px;">
            <a href="/student/assignments/bulk-upload" class="btn-secondary-outline">Bulk Upload</a>
            <a href="/student/assignments/upload" class="btn-upload">Upload Assignment</a>
          </div>
        </header>

        <% if (successMessage) { %>
          <div class="alert alert-success" style="margin-bottom: 24px; padding: 12px 16px; background-color: hsla(150, 80%, 95%, 0.9); border-left: 4px solid hsl(150, 80%, 40%); color: hsl(150, 80%, 25%); border-radius: var(--radius-sm);">
            <strong>Success:</strong> <%= successMessage %>
          </div>
        <% } %>

        <div class="filter-bar" style="display: flex; gap: 16px; margin-bottom: 24px; background-color: var(--card-bg); padding: 16px; border-radius: var(--radius-md); border: 1px solid var(--border-color);">
          <div style="flex: 1; min-width: 150px;">
            <label for="statusFilter" style="display: block; font-size: 12px; font-weight: 600; text-transform: uppercase; color: var(--text-muted); margin-bottom: 6px;">Filter Status</label>
            <select id="statusFilter" class="form-select" style="width: 100%; height: 38px;">
              <option value="All">All Statuses</option>
              <option value="Draft">Draft</option>
              <option value="Submitted">Submitted</option>
              <option value="Approved">Approved</option>
              <option value="Rejected">Rejected</option>
            </select>
          </div>
          <div style="flex: 1; min-width: 150px;">
            <label for="dateSort" style="display: block; font-size: 12px; font-weight: 600; text-transform: uppercase; color: var(--text-muted); margin-bottom: 6px;">Sort Date</label>
            <select id="dateSort" class="form-select" style="width: 100%; height: 38px;">
              <option value="desc">Newest First</option>
              <option value="asc">Oldest First</option>
            </select>
          </div>
        </div>

        <div class="table-container">
          <table class="admin-table sortable-table" id="assignmentsTable">
            <thead>
              <tr>
                <th>Assignment Title</th>
                <th>Category</th>
                <th>Submitted Date</th>
                <th>Current Reviewer</th>
                <th style="text-align: right; padding-right: 24px;">Status</th>
              </tr>
            </thead>
            <tbody>
              <% if (assignments.length === 0) { %>
                <tr id="emptyRow">
                  <td colspan="5" style="text-align: center; color: var(--text-muted); padding: 32px;">
                    No assignments found.
                  </td>
                </tr>
              <% } else { %>
                <% assignments.forEach(a => { %>
                  <tr class="assignment-row" 
                      data-id="<%= a.id %>"
                      data-title="<%= a.title %>"
                      data-category="<%= a.category %>"
                      data-status="<%= a.status %>"
                      data-date="<%= new Date(a.createdAt).toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' }) %>"
                      data-rawdate="<%= a.createdAt %>"
                      data-reviewer="<%= a.reviewer ? a.reviewer.name : 'Not Assigned' %>"
                      data-description="<%= a.description || 'No description provided.' %>"
                      data-filepath="<%= a.filePath %>">
                    <td style="font-weight: 600;"><%= a.title %></td>
                    <td><%= a.category %></td>
                    <td><%= new Date(a.createdAt).toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' }) %></td>
                    <td><%= a.reviewer ? a.reviewer.name : 'Not Assigned' %></td>
                    <td style="text-align: right; padding-right: 24px;">
                      <span class="badge badge-<%= a.status.toLowerCase() %>" style="display: inline-flex; justify-content: center; width: 90px; text-align: center;"><%= a.status %></span>
                    </td>
                  </tr>
                <% }); %>
              <% } %>
            </tbody>
          </table>
        </div>
      </main>
    </div>

    <!-- Details Overlay Modal -->
    <div class="modal-backdrop" id="detailModal">
      <div class="modal-box">
        <div class="modal-header">
          <h3 class="modal-title">Assignment Details</h3>
          <button class="modal-close" id="modalCloseBtn">&times;</button>
        </div>
        <div class="modal-body">
          <div class="modal-field">
            <div class="modal-label">Assignment ID</div>
            <div class="modal-value" id="modalId" style="font-weight: 700;"></div>
          </div>
          <div class="modal-field">
            <div class="modal-label">Title</div>
            <div class="modal-value" id="modalTitle" style="font-weight: 600; font-size: 16px;"></div>
          </div>
          <div class="modal-field" style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div>
              <div class="modal-label">Category</div>
              <div class="modal-value" id="modalCategory"></div>
            </div>
            <div>
              <div class="modal-label">Status</div>
              <div id="modalStatusBadge"></div>
            </div>
          </div>
          <div class="modal-field" style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div>
              <div class="modal-label">Submitted Date</div>
              <div class="modal-value" id="modalDate"></div>
            </div>
            <div>
              <div class="modal-label">Current Reviewer</div>
              <div class="modal-value" id="modalReviewer"></div>
            </div>
          </div>
          <div class="modal-field">
            <div class="modal-label">Notes / Description</div>
            <div class="modal-value" id="modalDescription" style="white-space: pre-wrap; background-color: var(--bg-main); padding: 12px; border-radius: var(--radius-sm); border: 1px solid var(--border-color); font-size: 14px; line-height: 1.5;"></div>
          </div>
          <div class="modal-field" style="margin-bottom: 0;">
            <div class="modal-label">Attachment</div>
            <a id="modalFileLink" href="" target="_blank" class="btn-secondary-outline" style="margin-top: 8px;">Download PDF</a>
          </div>
          <div class="modal-field" id="modalSubmitSection" style="margin-top: 24px; border-top: 1px dashed var(--border-color); padding-top: 20px; display: none;">
            <div class="modal-label" style="color: var(--primary); font-weight: 700;">Submit for Review</div>
            <p style="font-size: 13px; color: var(--text-muted); margin-bottom: 12px; margin-top: 4px;">Choose a professor from your department to assign as reviewer.</p>
            <form id="modalSubmitForm" action="" method="POST">
              <select name="reviewerId" id="modalReviewerSelect" class="form-select" style="width: 100%; height: 38px; margin-bottom: 16px;" required>
                <option value="" disabled selected>Select professor...</option>
                <% professors.forEach(p => { %>
                  <option value="<%= p.id %>"><%= p.name %> (<%= p.email %>)</option>
                <% }); %>
              </select>
              <button type="submit" class="btn-upload" style="width: 100%;">Submit Assignment</button>
            </form>
          </div>
        </div>
      </div>
    </div>

    <footer class="admin-footer">
      <p>&copy; 2025 Student Portal. All rights reserved.</p>
    </footer>
  </div>

  <script src="/scripts/my-assignments.js"></script>
</body>
</html>
