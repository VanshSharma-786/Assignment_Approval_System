<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Professor Dashboard | Portal</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="admin-layout">
    <header class="admin-header-bar">
      <a href="/professor/dashboard" class="admin-logo-title" style="color: inherit;">Professor Portal</a>
      <div class="navbar-menu" style="margin: 0;">
        <div class="user-profile">
          <div class="user-avatar" id="avatar-display">
            <%= user.role === 'professor' ? 'P' : (user.role === 'hod' ? 'H' : user.name.charAt(0).toUpperCase()) %>
          </div>
          <span><%= user.email %></span>
        </div>
        <form action="/auth/logout" method="GET" style="margin: 0;">
          <button type="submit" class="btn-logout" id="logout-btn">Sign Out</button>
        </form>
      </div>
    </header>

    <div class="admin-container">
      <aside class="admin-sidebar">
        <h2 class="sidebar-title">Navigation</h2>
        <nav class="sidebar-menu">
          <a href="/professor/dashboard" class="sidebar-link" style="background-color: var(--primary); color: var(--text-inverse);">Dashboard</a>
          <a href="/professor/reviews" class="sidebar-link">My Reviews</a>
          <a href="/professor/profile" class="sidebar-link">Profile</a>
        </nav>
      </aside>

      <main class="admin-content">
        <header class="dashboard-header" style="margin-bottom: 24px;">
          <h2 class="dashboard-title" style="font-size: 22px; margin: 0;">Professor Dashboard</h2>
        </header>

        <% if (locals.successMessage) { %>
          <div class="alert alert-success" style="margin-bottom: 24px; padding: 12px 16px; background-color: hsla(150, 80%, 95%, 0.9); border-left: 4px solid hsl(150, 80%, 40%); color: hsl(150, 80%, 25%); border-radius: var(--radius-sm); font-size: 14px; font-weight: 600;">
            <strong>Success:</strong> <%= successMessage %>
          </div>
        <% } %>

        <% if (notifications && notifications.length > 0) { %>
          <div id="notificationsPanel" style="margin-bottom: 24px;">
            <% notifications.forEach(n => { %>
              <div class="alert alert-info notification-alert" data-id="<%= n.id %>" style="margin-bottom: 12px; padding: 12px 16px; background-color: hsla(200, 80%, 95%, 0.9); border-left: 4px solid hsl(200, 80%, 40%); color: hsl(200, 80%, 25%); border-radius: var(--radius-sm); display: flex; justify-content: space-between; align-items: center; box-shadow: var(--shadow-sm);">
                <div>
                  <strong>Notification:</strong> <%= n.message %>
                </div>
                <button class="dismiss-notification-btn" style="background: transparent; border: none; color: inherit; cursor: pointer; font-size: 18px; font-weight: bold; padding: 4px; line-height: 1;">&times;</button>
              </div>
            <% }); %>
          </div>
        <% } %>

        <div class="dashboard-stats" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 32px;">
          <div class="stat-card" style="background-color: hsla(228, 80%, 95%, 0.5); border-left: 4px solid hsl(228, 80%, 60%); padding: 24px; border-radius: var(--radius-md); box-shadow: var(--shadow-sm); border-top: 1px solid var(--border-color); border-right: 1px solid var(--border-color); border-bottom: 1px solid var(--border-color);">
            <div class="stat-label" style="font-size: 13px; font-weight: 600; text-transform: uppercase; color: var(--text-muted); margin-bottom: 8px;">Pending Reviews</div>
            <div class="stat-value" style="font-size: 28px; font-weight: 700; color: var(--text-main);"><%= stats.pending %></div>
          </div>
          <div class="stat-card" style="background-color: hsla(142, 70%, 95%, 0.5); border-left: 4px solid hsl(142, 70%, 45%); padding: 24px; border-radius: var(--radius-md); box-shadow: var(--shadow-sm); border-top: 1px solid var(--border-color); border-right: 1px solid var(--border-color); border-bottom: 1px solid var(--border-color);">
            <div class="stat-label" style="font-size: 13px; font-weight: 600; text-transform: uppercase; color: var(--text-muted); margin-bottom: 8px;">Approved</div>
            <div class="stat-value" style="font-size: 28px; font-weight: 700; color: var(--text-main);"><%= stats.approved %></div>
          </div>
          <div class="stat-card" style="background-color: hsla(0, 80%, 95%, 0.5); border-left: 4px solid hsl(0, 80%, 60%); padding: 24px; border-radius: var(--radius-md); box-shadow: var(--shadow-sm); border-top: 1px solid var(--border-color); border-right: 1px solid var(--border-color); border-bottom: 1px solid var(--border-color);">
            <div class="stat-label" style="font-size: 13px; font-weight: 600; text-transform: uppercase; color: var(--text-muted); margin-bottom: 8px;">Rejected</div>
            <div class="stat-value" style="font-size: 28px; font-weight: 700; color: var(--text-main);"><%= stats.rejected %></div>
          </div>
          <div class="stat-card" style="background-color: hsla(170, 60%, 95%, 0.5); border-left: 4px solid hsl(170, 60%, 45%); padding: 24px; border-radius: var(--radius-md); box-shadow: var(--shadow-sm); border-top: 1px solid var(--border-color); border-right: 1px solid var(--border-color); border-bottom: 1px solid var(--border-color);">
            <div class="stat-label" style="font-size: 13px; font-weight: 600; text-transform: uppercase; color: var(--text-muted); margin-bottom: 8px;">Total Reviewed</div>
            <div class="stat-value" style="font-size: 28px; font-weight: 700; color: var(--text-main);"><%= stats.total %></div>
          </div>
        </div>

        <section class="review-section">
          <h3 style="font-size: 18px; font-weight: 700; margin-bottom: 20px; color: var(--text-main);">Assignments Awaiting Review</h3>
          
          <% if (assignments.length === 0) { %>
            <div style="background-color: var(--bg-card); padding: 40px; border-radius: var(--radius-md); border: 1px solid var(--border-color); text-align: center; color: var(--text-muted); font-size: 14px; box-shadow: var(--shadow-sm);">
              No assignments awaiting review.
            </div>
          <% } else { %>
            <div style="display: flex; flex-direction: column; gap: 16px;">
              <% assignments.forEach(a => { %>
                <% 
                   const submittedDate = a.updatedAt || a.createdAt;
                   const diffTime = Math.abs(new Date() - new Date(submittedDate));
                   const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
                %>
                <div style="background-color: var(--bg-card); border-radius: var(--radius-md); border: 1px solid var(--border-color); padding: 20px; display: flex; justify-content: space-between; align-items: center; box-shadow: var(--shadow-sm);">
                  <div>
                    <h4 style="font-size: 16px; font-weight: 600; color: var(--text-main); margin-bottom: 6px;">
                      <%= a.student ? a.student.name : 'Unknown Student' %> - <%= a.title %>
                    </h4>
                    <div style="font-size: 13px; color: var(--text-muted);">
                      Submitted: <%= new Date(submittedDate).toLocaleDateString(undefined, { day: 'numeric', month: 'short', year: 'numeric' }) %> &bull; <%= diffDays %> <%= diffDays === 1 ? 'day' : 'days' %> pending
                    </div>
                  </div>
                  <div style="display: flex; gap: 12px;">
                    <a href="/professor/assignments/<%= a.id %>/review" class="btn-upload" style="margin: 0; padding: 8px 16px; font-size: 13px; font-weight: 600; border-radius: var(--radius-sm);">Review</a>
                    <a href="/professor/assignments/<%= a.id %>" class="btn-secondary-outline" style="margin: 0; padding: 8px 16px; font-size: 13px; font-weight: 600; border-radius: var(--radius-sm);">Details</a>
                  </div>
                </div>
              <% }); %>
            </div>
          <% } %>
        </section>

        <a href="/professor/reviews" style="display: inline-block; margin-top: 24px; font-weight: 600; color: var(--primary);">
          View All Assignments &rarr;
        </a>
      </main>
    </div>

    <footer class="admin-footer">
      <p>&copy; 2025 Professor Portal. All rights reserved.</p>
    </footer>
  </div>

  <script src="/scripts/professor-dashboard.js"></script>
</body>
</html>
