<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Student Dashboard | University Assignment Approval</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="admin-layout">
    <header class="admin-header-bar">
      <a href="/student/dashboard" class="admin-logo-title" style="color: inherit;">Student Portal</a>
      <div class="navbar-menu" style="margin: 0;">
        <div class="user-profile">
          <div class="user-avatar" id="avatar-display">
            <%= user.name.charAt(0).toUpperCase() %>
          </div>
          <span><%= user.email %></span>
        </div>
        <form action="/auth/logout" method="GET" style="margin: 0;">
          <button type="submit" class="btn-logout" id="logout-btn">Sign Out</button>
        </form>
      </div>
    </header>

    <div class="admin-container">
      <aside class="admin-sidebar">
        <h2 class="sidebar-title">Navigation</h2>
        <nav class="sidebar-menu">
          <a href="/student/dashboard" class="sidebar-link" style="background-color: var(--primary); color: var(--text-inverse);">Dashboard</a>
          <a href="/student/assignments" class="sidebar-link">All Assignments</a>
          <a href="/student/profile" class="sidebar-link">Profile</a>
        </nav>
      </aside>

      <main class="admin-content">
        <header class="dashboard-header" style="margin-bottom: 24px;">
          <h2 class="dashboard-title" style="font-size: 22px;">Assignment Dashboard</h2>
        </header>

        <% if (successMessage) { %>
          <div class="alert alert-success" style="margin-bottom: 24px; padding: 12px 16px; background-color: hsla(150, 80%, 95%, 0.9); border-left: 4px solid hsl(150, 80%, 40%); color: hsl(150, 80%, 25%); border-radius: var(--radius-sm);">
            <strong>Success:</strong> <%= successMessage %>
          </div>
        <% } %>

        <div class="stats-grid" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 32px;">
          <div class="stat-card card-draft">
            <h3 class="stat-title" style="color: hsl(240, 70%, 40%); font-weight: 500;">Draft</h3>
            <p class="stat-value" style="color: hsl(240, 70%, 20%); font-size: 32px;"><%= stats.draft %></p>
          </div>
          <div class="stat-card card-submitted">
            <h3 class="stat-title" style="color: hsl(160, 70%, 30%); font-weight: 500;">Submitted</h3>
            <p class="stat-value" style="color: hsl(160, 70%, 15%); font-size: 32px;"><%= stats.submitted %></p>
          </div>
          <div class="stat-card card-approved">
            <h3 class="stat-title" style="color: hsl(90, 70%, 30%); font-weight: 500;">Approved</h3>
            <p class="stat-value" style="color: hsl(90, 70%, 15%); font-size: 32px;"><%= stats.approved %></p>
          </div>
          <div class="stat-card card-rejected">
            <h3 class="stat-title" style="color: hsl(0, 70%, 40%); font-weight: 500;">Rejected</h3>
            <p class="stat-value" style="color: hsl(0, 70%, 20%); font-size: 32px;"><%= stats.rejected %></p>
          </div>
        </div>

        <div style="display: flex; justify-content: space-between; align-items: center; margin: 32px 0 16px;">
          <h3 style="font-size: 18px; font-weight: 600; color: var(--text-main); margin: 0;">Recent Submissions</h3>
          <div style="display: flex; gap: 12px; align-items: center;">
            <a href="/student/assignments/bulk-upload" class="btn-secondary-outline">Bulk Upload Assignments</a>
            <a href="/student/assignments/upload" class="btn-upload">Upload New Assignment</a>
          </div>
        </div>

        <div class="table-container" style="margin-bottom: 24px;">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Assignment Title</th>
                <th style="text-align: right; padding-right: 24px;">Status</th>
              </tr>
            </thead>
            <tbody>
              <% if (recentSubmissions.length === 0) { %>
                <tr>
                  <td colspan="2" style="text-align: center; color: var(--text-muted); padding: 32px;">
                    No assignments submitted yet.
                  </td>
                </tr>
              <% } else { %>
                <% recentSubmissions.forEach(a => { %>
                  <tr>
                    <td style="font-weight: 500;"><%= a.title %></td>
                    <td style="text-align: right; padding-right: 24px;">
                      <span class="badge badge-<%= a.status.toLowerCase() %>" style="display: inline-flex; justify-content: center; width: 90px; text-align: center;"><%= a.status %></span>
                    </td>
                  </tr>
                <% }); %>
              <% } %>
            </tbody>
          </table>
        </div>

        <div style="margin-top: 16px;">
          <a href="/student/assignments" style="color: var(--primary); font-weight: 600; text-decoration: none; font-size: 15px;">View All Assignments &rarr;</a>
        </div>
      </main>
    </div>

    <footer class="admin-footer">
      <p>&copy; 2025 Student Portal. All rights reserved.</p>
    </footer>
  </div>
</body>
</html>
