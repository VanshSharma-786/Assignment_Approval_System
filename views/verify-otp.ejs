<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Verify OTP | Professor Portal</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="login-container">
    <div class="login-card" style="width: 100%; max-width: 400px; padding: 32px; background-color: var(--bg-card); border-radius: var(--radius-lg); box-shadow: var(--shadow-xl); border: 1px solid var(--border-color);">
      <h2 style="font-size: 20px; font-weight: 700; text-align: center; margin-bottom: 8px; color: var(--text-main);">OTP Verification</h2>
      <p style="font-size: 13px; text-align: center; color: var(--text-muted); margin-bottom: 24px;">
        A 6-digit verification code has been dispatched to <strong><%= user.email %></strong>.
      </p>

      <% if (error) { %>
        <div class="alert alert-danger" style="margin-bottom: 16px; padding: 10px 12px; background-color: var(--error-bg); border-left: 4px solid var(--error-text); color: var(--error-text); border-radius: var(--radius-sm); font-size: 13px;">
          <%= error %>
        </div>
      <% } %>

      <form action="/professor/assignments/<%= assignmentId %>/verify-otp" method="POST">
        <div style="margin-bottom: 20px;">
          <label for="otp" style="display: block; font-size: 12px; font-weight: 600; text-transform: uppercase; color: var(--text-muted); margin-bottom: 8px;">Enter Verification OTP</label>
          <input type="text" id="otp" name="otp" class="form-control" style="width: 100%; text-align: center; font-size: 20px; font-weight: 700; letter-spacing: 4px; height: 48px;" placeholder="000000" maxlength="6" required autofocus>
          <p style="font-size: 11px; text-align: center; color: var(--text-muted); margin-top: 8px;">Code expires in 10 minutes.</p>
        </div>

        <button type="submit" class="btn-login" style="width: 100%; height: 44px; font-size: 14px; font-weight: 600;">Verify OTP</button>
      </form>
      
      <div style="text-align: center; margin-top: 16px;">
        <a href="/professor/assignments/<%= assignmentId %>/review" style="font-size: 13px; text-decoration: underline; color: var(--text-muted);">Cancel Review</a>
      </div>
    </div>
  </div>
</body>
</html>
